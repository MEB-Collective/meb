\newcommand{\essaytitle}[1]{%
  \setcounter{theorem}{0}%
  \setcounter{figure}{0}%
  \setcounter{table}{0}%
  \setcounter{equation}{0}%
  \section*{\begin{center}#1\end{center}}%
}
\newcommand{\essayauthor}[1]{\begin{flushright}\small \textit{#1}\end{flushright}}
\newcommand{\essaysetup}[2]{\essaytitle{#1} \vspace{-0.5cm}\essayauthor{#2}}

\makeatletter
\let\meb@origessayauthor\essayauthor
\let\meb@origessaysetup\essaysetup

\newcommand{\currentessayauthor}{}
\newcommand{\currentessaytitle}{}

\renewcommand{\essayauthor}[1]{
  \gdef\currentessayauthor{#1}
  \meb@origessayauthor{#1}
}

\renewcommand{\essaysetup}[2]{
  \gdef\currentessaytitle{#1}
  \meb@origessaysetup{#1}{#2}
  \addcontentsline{toc}{section}{#1\ \textnormal{(\currentessayauthor)}}
}
